{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Train model",
            "type": "debugpy",
            "request": "launch",
            "module": "app.ml.train",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Debug FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8001"],
            "env": {
                "DATABASE_URL": "postgresql://finai:finai_secret@localhost:5432/finai"
            },
            "jinja": true
        }
    ]
}